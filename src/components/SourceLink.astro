---
type Props = {
  sourceNote?: string;
  sourceLabel: string;
  sourceUrl: string;
  localPdfAsset?: string;
};

const { sourceNote, sourceLabel, sourceUrl, localPdfAsset } = Astro.props;
---

<section class="panel rounded-[1.75rem] px-5 py-5">
  <p class="section-kicker">Source Note</p>
  <h2 class="mt-2 font-display text-[2rem] text-[var(--text)]">Original Detailed Reading</h2>
  <p class="mt-3 text-sm leading-7 text-[var(--muted)]">
    {sourceNote ?? 'This page has been adapted for direct reading on the web. The original long-form source remains available below.'}
  </p>
  <a
    href={sourceUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-5 inline-flex min-h-12 items-center justify-center rounded-full border border-[rgba(214,179,106,0.34)] bg-[linear-gradient(135deg,rgba(214,179,106,0.16),rgba(156,47,31,0.14))] px-5 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--text)]"
  >
    {sourceLabel}
  </a>
  {
    localPdfAsset ? (
      <p class="mt-4 text-xs leading-6 text-[rgba(246,239,221,0.58)]">
        Local PDF archive detected for editorial reference: {localPdfAsset}
      </p>
    ) : null
  }
</section>
