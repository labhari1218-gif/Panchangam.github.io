---
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const enterPath = `${basePath}enter/`;
---

<a
  href={enterPath}
  data-back-rasi
  class="inline-flex min-h-11 items-center gap-2 rounded-full border border-[rgba(214,179,106,0.2)] px-4 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--muted)]"
>
  <span aria-hidden="true">←</span>
  <span>Back to Rasi Selection</span>
</a>

<script is:inline>
  document.querySelectorAll('[data-back-rasi]').forEach((node) => {
    node.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('ugadi:play', { detail: { sound: 'click' } }));
    });
  });
</script>
