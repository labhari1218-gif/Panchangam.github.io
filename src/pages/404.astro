---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const enterPath = `${basePath}enter/`;
---

<BaseLayout
  title="Page Not Found | Ugadi 2026"
  description="Return to the Ugadi 2026 zodiac selector."
>
  <main class="safe-container flex min-h-screen items-center">
    <section class="panel w-full rounded-[2rem] px-6 py-8 text-center">
      <p class="section-kicker">404</p>
      <h1 class="mt-3 font-display text-[3rem] text-[var(--text)]">This page is not on the current chart.</h1>
      <p class="mt-3 text-sm leading-7 text-[var(--muted)]">
        Return to the zodiac selector and continue with the Ugadi Panchangam experience.
      </p>
      <a
        href={enterPath}
        class="mt-6 inline-flex min-h-12 items-center justify-center rounded-full border border-[rgba(214,179,106,0.34)] px-5 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--text)]"
      >
        Return to Rasi Selection
      </a>
    </section>
  </main>
</BaseLayout>
